{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

    // Enable linting on save and set the provider
    "editor.codeActionsOnSave": {
        "source.fixAll.flake8": "explicit"
    },
    "python.linting.enabled": true,
    "python.linting.flake8.enabled": true,
    "python.linting.lintOnSave": true,

    // Run the Flake8 server with the workspace virtualenv and bundled toolchain.
    "flake8.interpreter": ["${workspaceFolder}/.venv/bin/python"],
    "flake8.importStrategy": "useBundled",

    // Optional: Pass arguments to Flake8 for customization
    "flake8.args": [
        "--max-line-length=79",
        // "--ignore=E203,E402,W503"
    ],
    "black-formatter.args": [
        "--line-length=79"
    ],

    // Optional: Default formatter (Black is a common choice)
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        // Keep formatting explicit so auto-save cannot rewrite code unexpectedly.
        "editor.formatOnSave": false,
        "files.insertFinalNewline": true,
        "editor.rulers": [79],
        "editor.tabSize": 4,
        "editor.insertSpaces": false
    }
}
